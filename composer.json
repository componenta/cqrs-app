{
    "name": "componenta/cqrs-app",
    "description": "Componenta application integration for CQRS discovery compilation",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "componenta/app": "^1.0",
        "componenta/arrayable": "^1.0",
        "componenta/class-finder": "^1.0",
        "componenta/config": "^1.0",
        "componenta/cqrs": "^1.0",
        "componenta/tokenizer": "^1.0",
        "psr/container": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\CQRS\\App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Componenta\\CQRS\\App\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "minimum-stability": "stable",
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\CQRS\\App\\ConfigProvider"
            ]
        }
    }
}
